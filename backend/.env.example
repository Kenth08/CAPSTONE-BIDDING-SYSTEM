# Copy this file to ".env" and fill in your Supabase credentials.
# Find these in Supabase: Project Settings -> Database -> Connection info
# (use the "Session pooler" / port 5432 values, or the direct connection).

DB_NAME=postgres
DB_USER=postgres.your-project-ref
DB_PASSWORD=your-database-password
DB_HOST=aws-0-xxxx.pooler.supabase.com
DB_PORT=5432

# Optional: SMTP creds so password-reset emails actually get delivered.
# Leave unset and emails are just printed to the server console (fine for dev).
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=your-address@gmail.com
EMAIL_HOST_PASSWORD=your-app-password
DEFAULT_FROM_EMAIL=no-reply@eprocurement.local
